{
  "name": "openclaude-vscode",
  "displayName": "OpenClaude VS Code",
  "description": "Acesse rapidamente o OpenClaude diretamente do VS Code com um clique, atalho de teclado ou botão na barra de status.",
  "version": "0.6.2",
  "publisher": "EXABIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/git-exahost/openclaude-vscode"
  },
  "icon": "images/icone.png",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "scripts": {
    "lint": "eslint .",
    "package": "vsce package",
    "package:out": "node scripts/package.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0"
  },
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "openclaude-vscode.open",
        "title": "Abrir OpenClaude",
        "icon": {
          "light": "images/button-light.svg",
          "dark": "images/button-dark.svg"
        }
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "openclaude-vscode.open",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "openclaude-vscode.open",
        "title": "Abrir OpenClaude",
        "key": "ctrl+escape",
        "mac": "cmd+escape",
        "win": "ctrl+escape",
        "linux": "ctrl+escape"
      }
    ]
  }
}